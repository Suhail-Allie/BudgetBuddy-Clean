<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/bb_surface_soft" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/bb_primary_dark" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/bb_surface" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/bb_primary" />
        </shape>
    </item>

</selector>