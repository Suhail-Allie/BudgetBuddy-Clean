<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.BudgetBuddy" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bb_primary</item>
        <item name="colorPrimaryVariant">@color/bb_primary_dark</item>
        <item name="colorOnPrimary">@color/bb_text_on_primary</item>

        <item name="colorSecondary">@color/bb_accent</item>
        <item name="colorSecondaryVariant">@color/bb_accent_dark</item>
        <item name="colorOnSecondary">@color/bb_text_primary</item>

        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/bb_primary_dark</item>
        <item name="android:navigationBarColor">@color/bb_primary_dark</item>

        <item name="android:windowBackground">@color/bb_background</item>
        <item name="android:colorAccent">@color/bb_accent</item>

        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

</resources>