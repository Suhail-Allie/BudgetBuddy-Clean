<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/addExpenseDialogScroll"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bb_background"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header text inside dialog -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Expense Details"
            android:textColor="@color/bb_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:text="Record the amount, date, category and optional receipt."
            android:textColor="@color/bb_text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etExpenseTitle"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_input"
            android:hint="Description / title"
            android:inputType="textCapSentences"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:singleLine="true"
            android:textColor="@color/bb_text_primary"
            android:textColorHint="@color/bb_text_secondary"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etExpenseAmount"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Amount (R)"
            android:inputType="numberDecimal"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:singleLine="true"
            android:textColor="@color/bb_text_primary"
            android:textColorHint="@color/bb_text_secondary"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etExpenseDate"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:clickable="true"
            android:focusable="false"
            android:hint="Date"
            android:inputType="none"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:singleLine="true"
            android:textColor="@color/bb_text_primary"
            android:textColorHint="@color/bb_text_secondary"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="sans-serif-medium"
            android:text="Category"
            android:textColor="@color/bb_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingLeft="8dp"
            android:paddingRight="8dp">

            <Spinner
                android:id="@+id/spExpenseCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <EditText
            android:id="@+id/etExpenseNotes"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:gravity="top"
            android:hint="Notes (optional)"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            android:paddingLeft="14dp"
            android:paddingTop="12dp"
            android:paddingRight="14dp"
            android:paddingBottom="12dp"
            android:textColor="@color/bb_text_primary"
            android:textColorHint="@color/bb_text_secondary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnTakePhoto"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Attach Receipt Photo"
            android:textAllCaps="false"
            android:textColor="@color/bb_primary_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivReceiptPreview"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:contentDescription="Receipt preview"
            android:scaleType="centerCrop"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>