<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/registerScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App Branding -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_badge"
                android:gravity="center"
                android:text="🚀"
                android:textSize="34sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Create Account"
                android:textColor="@color/bb_text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Start building better budgeting habits today"
                android:textColor="@color/bb_text_secondary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Register Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="5dp"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Register"
                android:textColor="@color/bb_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Create your BudgetBuddy profile."
                android:textColor="@color/bb_text_secondary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etNewUsername"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_input"
                android:hint="Username"
                android:inputType="text"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:singleLine="true"
                android:textColor="@color/bb_text_primary"
                android:textColorHint="@color/bb_text_secondary"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etNewPassword"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="Password"
                android:inputType="textPassword"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:singleLine="true"
                android:textColor="@color/bb_text_primary"
                android:textColorHint="@color/bb_text_secondary"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="Confirm password"
                android:inputType="textPassword"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:singleLine="true"
                android:textColor="@color/bb_text_primary"
                android:textColorHint="@color/bb_text_secondary"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_button_primary"
                android:text="Create Account"
                android:textAllCaps="false"
                android:textColor="@color/bb_text_on_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBackToLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:padding="8dp"
                android:text="Already have an account? Login"
                android:textColor="@color/bb_primary_dark"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:text="Your budget. Your goals. Your progress."
            android:textColor="@color/bb_text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

</ScrollView>