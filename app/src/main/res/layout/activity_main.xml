<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dashboardScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvWelcomeUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Welcome"
                android:textColor="@color/bb_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Track your money. Build better habits."
                android:textColor="@color/bb_text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Balance Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current Balance"
                android:textColor="@color/bb_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif-medium"
                android:text="Balance: R0.00"
                android:textColor="@color/bb_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvGoals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Goals: Not set"
                android:textColor="@color/bb_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvCategoryCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Categories available: 1"
                android:textColor="@color/bb_text_secondary"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Budget Progress Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Monthly Budget Progress"
                android:textColor="@color/bb_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMonthlySpent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="This month spent: R0.00"
                android:textColor="@color/bb_text_secondary"
                android:textSize="14sp" />

            <ProgressBar
                android:id="@+id/progressBudget"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:layout_marginTop="12dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/bg_progress" />

            <TextView
                android:id="@+id/tvBudgetPercent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0% of maximum monthly goal used"
                android:textColor="@color/bb_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvBudgetStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-medium"
                android:text="Set budget goals to track your progress."
                android:textColor="@color/bb_primary_dark"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Badges Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Rewards &amp; Badges"
                android:textColor="@color/bb_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBadges"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_badge"
                android:text="Badges: Add expenses and stay within your goals to unlock rewards."
                android:textColor="@color/bb_text_primary"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Quick Income / Expense Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Quick Actions"
                android:textColor="@color/bb_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="Enter income amount or pre-fill expense amount"
                android:inputType="numberDecimal"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="@color/bb_text_primary"
                android:textColorHint="@color/bb_text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnAddIncome"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_primary"
                android:text="Add Income"
                android:textAllCaps="false"
                android:textColor="@color/bb_text_on_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAddExpense"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Add Expense Details"
                android:textAllCaps="false"
                android:textColor="@color/bb_primary_dark"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Navigation Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Manage Budget"
                android:textColor="@color/bb_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnManageCategories"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_primary"
                android:text="Manage Categories"
                android:textAllCaps="false"
                android:textColor="@color/bb_text_on_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnBudgetGoals"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_primary"
                android:text="Set Budget Goals"
                android:textAllCaps="false"
                android:textColor="@color/bb_text_on_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnFilter"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_primary"
                android:text="Filter Expenses by Date"
                android:textAllCaps="false"
                android:textColor="@color/bb_text_on_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnViewReports"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_primary"
                android:text="View Reports"
                android:textAllCaps="false"
                android:textColor="@color/bb_text_on_primary"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Session Transactions Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Recent Session Activity"
                android:textColor="@color/bb_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTransactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:text="No transactions added in this session yet"
                android:textColor="@color/bb_text_secondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnClearHistory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Clear Screen History"
                android:textAllCaps="false"
                android:textColor="@color/bb_primary_dark"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Logout -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_button_primary"
            android:text="Logout"
            android:textAllCaps="false"
            android:textColor="@color/bb_text_on_primary"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>