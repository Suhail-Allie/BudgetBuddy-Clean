<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/budgetGoalScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Budget Goals"
                android:textColor="@color/bb_text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Set your monthly spending range."
                android:textColor="@color/bb_text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Goal Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Current Goal"
                android:textColor="@color/bb_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvGoals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_badge"
                android:lineSpacingExtra="5dp"
                android:text="No goals saved yet"
                android:textColor="@color/bb_text_primary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Set Goals Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Set Monthly Range"
                android:textColor="@color/bb_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Your dashboard will use these values to show budget progress."
                android:textColor="@color/bb_text_secondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etMinGoal"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input"
                android:hint="Minimum monthly goal (R)"
                android:inputType="numberDecimal"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:singleLine="true"
                android:textColor="@color/bb_text_primary"
                android:textColorHint="@color/bb_text_secondary"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etMaxGoal"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="Maximum monthly goal (R)"
                android:inputType="numberDecimal"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:singleLine="true"
                android:textColor="@color/bb_text_primary"
                android:textColorHint="@color/bb_text_secondary"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnSaveGoals"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_primary"
                android:text="Save Goals"
                android:textAllCaps="false"
                android:textColor="@color/bb_text_on_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_button_primary"
            android:text="Back to Dashboard"
            android:textAllCaps="false"
            android:textColor="@color/bb_text_on_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>